{
	{$CADDY_GLOBAL_OPTIONS}

	frankenphp {
		{$FRANKENPHP_CONFIG}

		worker {
			file ./public/index_website.php
			env APP_RUNTIME Runtime\FrankenPhpSymfony\Runtime
			{$FRANKENPHP_WORKER_CONFIG}
		}

		worker {
			file ./public/index_admin.php
			env APP_RUNTIME Runtime\FrankenPhpSymfony\Runtime
			{$FRANKENPHP_WORKER_CONFIG}
		}
	}
}

{$CADDY_EXTRA_CONFIG}

{$SERVER_NAME:localhost} {
	log {
		{$CADDY_SERVER_LOG_OPTIONS}
	}

	root /app/public
	encode zstd br gzip

	{$CADDY_SERVER_EXTRA_DIRECTIVES}

	# Disable Topics tracking if not enabled explicitly: https://github.com/jkarlin/topics
	header ?Permissions-Policy "browsing-topics=()"

	@websiteRoute {
		path /fr /fr/* /en /en/* /media/* /uploads/media/* /_wdt/* /_profiler/*
		not file {path}
	}
	rewrite @websiteRoute index_website.php

	@adminRoute {
		not path /fr /fr/* /en /en/* /media/* /uploads/media/*
		not file {path}
	}
	rewrite @adminRoute index_admin.php

	@frontController path index_website.php index_admin.php
	php @frontController

	file_server {
		hide *.php
	}
}
