<?xml version="1.0" encoding="utf-8"?>
<webspace xmlns="http://schemas.sulu.io/webspace/webspace"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://schemas.sulu.io/webspace/webspace http://schemas.sulu.io/webspace/webspace-1.1.xsd">

    <name>Romain MILLAN</name>
    <key>romainmillan</key>

    <localizations>
        <localization language="fr" default="true"/>
        <localization language="en"/>
    </localizations>

    <default-templates>
        <default-template type="page">default</default-template>
        <default-template type="home">portfolio</default-template>
    </default-templates>

    <templates>
        <template type="search">search/search</template>
        <template type="error">error/error</template>
    </templates>

    <navigation>
        <contexts>
            <context key="main">
                <meta>
                    <title lang="fr">Navigation principale</title>
                    <title lang="en">Main Navigation</title>
                </meta>
            </context>
        </contexts>
    </navigation>

    <portals>
        <portal>
            <name>Romain MILLAN</name>
            <key>romainmillan</key>
            <environments>
                <environment type="prod">
                    <urls>
                        <url language="fr">{host}/fr</url>
                        <url language="en">{host}/en</url>
                    </urls>
                </environment>
                <environment type="dev">
                    <urls>
                        <url language="fr">{host}/fr</url>
                        <url language="en">{host}/en</url>
                    </urls>
                </environment>
                <environment type="test">
                    <urls>
                        <url language="fr">{host}/fr</url>
                        <url language="en">{host}/en</url>
                    </urls>
                </environment>
            </environments>
        </portal>
    </portals>
</webspace>
