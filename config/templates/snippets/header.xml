<?xml version="1.0" ?>
<template xmlns="http://schemas.sulu.io/template/template"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">

    <key>header</key>

    <meta>
        <title lang="fr">Navigation</title>
        <title lang="en">Navigation</title>
    </meta>

    <areas>
        <area key="header">
            <meta>
                <title lang="fr">En-tête</title>
                <title lang="en">Header</title>
            </meta>
        </area>
    </areas>

    <properties>
        <block name="nav_items" default-type="nav_link">
            <meta>
                <title lang="fr">Éléments de navigation</title>
                <title lang="en">Navigation items</title>
            </meta>
            <types>
                <type name="nav_link">
                    <meta>
                        <title lang="fr">Lien</title>
                        <title lang="en">Link</title>
                    </meta>
                    <properties>
                        <property name="label" type="text_line" mandatory="true">
                            <meta>
                                <title lang="fr">Libellé</title>
                                <title lang="en">Label</title>
                            </meta>
                        </property>
                        <property name="url" type="text_line" mandatory="true">
                            <meta>
                                <title lang="fr">URL</title>
                                <title lang="en">URL</title>
                            </meta>
                        </property>
                        <property name="target_blank" type="checkbox">
                            <meta>
                                <title lang="fr">Nouvel onglet</title>
                                <title lang="en">New tab</title>
                            </meta>
                        </property>
                    </properties>
                </type>
            </types>
        </block>
    </properties>
</template>
