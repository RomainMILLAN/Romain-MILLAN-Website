<!DOCTYPE html>
<html lang="{{ app.locale }}" {{ stimulus_controller('scroll-to theme') }}>
	<head>
		<title>
			Romain MILLAN
			{% block title %}{% endblock %}
		</title>

		<meta name="description" content="Portfolio de Romain MILLAN">
		<meta name="og:title" property="og:title" content="Romain MILLAN">
		<meta property="og:type" content="website">
		<meta property="og:url" content="https://www.romainmillan.fr/">

		{% block meta %}{% endblock %}

		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<meta http-equiv="Content-Type" content="text/html; charset=utf-8">

		<link rel="shortcut icon" href="{{ asset('build/app/static/img/logo/icon.svg', 'app') }}" type="image/x-icon">
		<link rel="mask-icon" href="{{ asset('build/app/static/img/logo/icon.svg', 'app') }}" color="#000000">

		<meta name="turbo-refresh-method" content="morph">
		<meta name="turbo-refresh-scroll" content="preserve">
		<meta name="turbo-prefetch" content="true">
		<meta name="view-transition" content="same-origin">

		{% block head '' %}

		{% block stylesheets %}
			{{ encore_entry_link_tags('front', null, 'front') }}
			{{ encore_entry_link_tags('app', null, 'app') }}
		{% endblock %}

		{% block javascripts %}
			<script type="text/javascript" src="{{ asset('tarteaucitron/tarteaucitron.js', 'front') }}"></script>
			{{ encore_entry_script_tags('front', null, 'front') }}
			{{ encore_entry_script_tags('app', null, 'app') }}
		{% endblock %}
	</head>

	<body {{ stimulus_target('theme', 'body') }} data-turbo="{% block turbo 'true' %}" {% block body_attribut %} {% endblock %}>

		{% set locale_prefix = '/' ~ app.request.locale %}
		{% set portfolio_url = locale_prefix ~ '/portfolio' %}
		{% set terms_url = locale_prefix ~ '/terms-of-use' %}

		<header {% block header_attributes '' %}>
			{% block header %}
				{% trans_default_domain 'app' %}
				{% set header_snippet = sulu_snippet_load_by_area('header') %}
				{% set nav_items = header_snippet is not null and header_snippet.content is defined ? header_snippet.content.nav_items|default(null) : null %}

				<section class="mobile_header">

					<div id="mobile_nav--container">

						<div class="mobile_nav--background"></div>
						<div class="mobile_nav--header">
							<a class="mobile_nav-logo" href="{{ portfolio_url }}">
								<img src="{{asset('static/img/logo/icon.svg', 'front')}}" alt="Icone RomainMILLAN"/>
							</a>
							<div class="mobile_nav--button" tabindex="110">
								<span class="mobile_nav--button_icon"></span>
								<span class="mobile_nav--button_icon"></span>
								<span class="mobile_nav--button_icon"></span>
							</div>
						</div>

						<div id="mobile_nav--content" tabindex="0">

							<ul>

								<twig:rm-tag
										width="230px"
										isFilledBlack="true"
										hasRedirect="true"
								/>

								{% for item in nav_items|default([]) %}
									{% set href = item.url starts with '/' ? locale_prefix ~ item.url : item.url %}

									<li>
										<a href="{{ href }}"{% if item.target_blank|default(false) %} target="_blank"{% endif %}>{{ item.label }}</a>
									</li>
								{% endfor %}

								{% if localizations is defined %}
									<li>
										<form action="#" class="language_picker--container">
											<label>
												<select
														onchange="this.options[this.selectedIndex].value && (window.location = this.options[this.selectedIndex].value);"
														name="language_picker--select"
												>
													{% for locale, localization in localizations %}
														<option lang="{{ locale }}"
															{% if locale == app.request.locale %}selected{% endif %}
															value="{{ localization.url }}">
															{{ locale|language_name(locale)|u.title }}
														</option>
													{% endfor %}
												</select>
											</label>
										</form>
									</li>
								{% endif %}

								<li class="nav_small">
									<p>© 2023-{{ 'now' | date('Y') }} <a href="{{ absolute_url(path('redirect')) }}" style="padding: 0; margin: 0;">{{ absolute_url(path('redirect')) }}</a>, {{ 'footer.all_right_reserved'|trans }}</p>
									<p>{{ 'footer.no_reproduce'|trans }}</p>
								</li>

							</ul>

						</div>
					</div>

				</section>

				<section class="desktop_header">

				<twig:rm-tag
						width="230px"
						isFilledBlack="true"
						hasRedirect="true"
				/>

				<nav class="desktop_header--navigation">
					{% for item in nav_items %}
						{% set href = item.url starts with '/' ? locale_prefix ~ item.url : item.url %}
						<a class="desktop_header--navigation_item cursor-pointer" 
							tabindex="0"
							href="{{ href }}"
							{% if item.target_blank|default(false) %}target="_blank"{% endif %}
						>
							{{ item.label }}
						</a>
					{% endfor %}

					{% if localizations is defined %}
						<form action="#" class="language_picker--container">
							<label>
								<select
										onchange="this.options[this.selectedIndex].value && (window.location = this.options[this.selectedIndex].value);"
										name="language_picker--select"
								>
									{% for locale, localization in localizations %}
										<option lang="{{ locale }}"
											{% if locale == app.request.locale %}selected{% endif %}
											value="{{ localization.url }}">
											{{ locale|language_name(locale)|u.title }}
										</option>
									{% endfor %}
								</select>
							</label>
						</form>
					{% endif %}

					<div class="theme_mode--container flex-row align-items-center justify-content-center">
						<div id="themeMode-light" class="theme_mode--item justify-content-center align-items-center" {{ stimulus_action('theme', 'switchToLightMode', 'click') }} {{ stimulus_target('theme', 'light') }}>
							<twig:ux:icon name="material-symbols:light-mode" width="25"/>
						</div>

						<div id="themeMode-dark" class="theme_mode--item flex-column justify-content-center align-items-center" {{ stimulus_action('theme', 'switchToDarkMode', 'click') }} {{ stimulus_target('theme', 'dark') }}>
							<twig:ux:icon  name="material-symbols:dark-mode" width="25"/>
						</div>
					</div>

					{% if app.user is not null %}
						<a href="{{ path('app_panel_dashboard') }}" class="btn btn-primary">{{ 'navigation.panel'|trans }}</a>
					{% endif %}
				</nav>

				</section>
			{% endblock %}
		</header>

		<main>
			{% block main %}{% block content %}{% endblock %}{% endblock %}
		</main>

		<footer {% block footer_attribut '' %}>
			{% block footer %}
				{% trans_default_domain 'app' %}
				{% set footer_snippet = sulu_snippet_load_by_area('footer') %}

				<div>
					<div class="footer_navigation--container flex-row align-items-start justify-content-start">

						<img src="{{ asset('static/img/logo/icon.svg', 'front') }}" alt="Icone Romain MILLAN"/>

						{% if footer_snippet is not null and footer_snippet.content is defined and footer_snippet.content.columns is defined %}
							{% for column in footer_snippet.content.columns %}
								<div class="footer_navigation--item flex-column m-0 p-0">
									<h6 class="text-underline m-0">{{ column.title }}</h6>
									{% if column.links is defined %}
										{% for link in column.links %}
											{% if link.type == 'media_link' and link.media.url is defined %}
												<a href="{{ link.media.url }}"{% if link.target_blank|default(false) %} target="_blank"{% endif %}>{{ link.label }}</a>
											{% else %}
												<a href="{{ link.url }}"{% if link.target_blank|default(false) %} target="_blank"{% endif %}>{{ link.label }}</a>
											{% endif %}
										{% endfor %}
									{% endif %}
								</div>
							{% endfor %}
						{% endif %}

					</div>

					<hr>

					<p class="text-italic">© 2023-{{ 'now' | date('Y') }} <a href="{{ absolute_url(path('redirect')) }}">{{ absolute_url(path('redirect')) }}</a>, {{ 'footer.all_right_reserved'|trans }}</p>
				</div>
			{% endblock %}
		</footer>

	</body>
</html>
