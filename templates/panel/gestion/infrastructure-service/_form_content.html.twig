<div class="d-flex flex-column flex-md-row justify-content-between">
    <div class="col-md-6 px-2 mb-3">
        <label class="form-label">{{ form_label(form.name) }}</label>
        {{ form_widget(form.name, {attr: {
            class: 'form-control',
        }}) }}
    </div>

    <div class="col-md-6 px-2 mb-3">
        <label class="form-label">{{ form_label(form.ipAddress) }}</label>
        {{ form_widget(form.ipAddress, {attr: {
            class: 'form-control',
        }}) }}
    </div>
</div>

<div class="px-2 mb-3">
    <label class="form-label">{{ form_label(form.applications) }}</label>
    {{ form_widget(form.applications, {attr: {
        class: 'form-control',
    }}) }}
</div>
